# ===========================
# Supabase Configuration
# ===========================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ===========================
# NextAuth Configuration
# ===========================
NEXTAUTH_SECRET=your_secret_key_here_min_32_characters
NEXTAUTH_URL=http://localhost:3000

# ===========================
# OAuth Providers (Optional)
# ===========================
# Google OAuth
GOOGLE_CLIENT_ID=your_google_oauth_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_oauth_secret

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_oauth_id
GITHUB_CLIENT_SECRET=your_github_oauth_secret

# ===========================
# Application URLs
# ===========================
# The base URL for shortened links
NEXT_PUBLIC_SHORT_URL_BASE=http://localhost:3000
# The domain where the app is hosted
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===========================
# Email Configuration (Optional)
# ===========================
# SMTP server for sending emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# ===========================
# Analytics Configuration (Optional)
# ===========================
# Sentry for error tracking
NEXT_PUBLIC_SENTRY_DSN=

# ===========================
# Short URL Configuration
# ===========================
SHORT_CODE_LENGTH=6

# ===========================
# Development Configuration
# ===========================
# Set to production for deployment
NODE_ENV=development
DEBUG=false
